VERSION 5.7 ;
   NAMESCASESENSITIVE ON ;
   DIVIDERCHAR "/" ;
   BUSBITCHARS "()" ;
   DESIGN housekeeping_top ;
   TECHNOLOGY ihp-sg13cmos5l ;
   UNITS DISTANCE MICRONS 1000 ;
