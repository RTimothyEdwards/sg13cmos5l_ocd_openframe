/*-----------------------------------------------------------------------*/
/* sg13cmos5l_padframe:  A 64-pad frame compatible with Efabless Caravel */
/*									 */
/* Written by:								 */
/* Tim Edwards								 */
/* Open Circuit Design, LLC						 */
/* February 2026							 */
/*-----------------------------------------------------------------------*/

`default_nettype none

/* Include netlists from the openframe top level */
// `include "netlists.v"

module sg13cmos5l_padframe(
`ifdef USE_POWER_PINS
    // Pad power connections
    inout wire vccd,
    inout wire vssd,
    inout wire vddio,
    inout wire vssio,
`endif	/* USE_POWER_PINS */

    // Pad signal connections
    inout wire [43:0] gpio,
    input wire resetb,
    input wire clock,
    input wire option,

    // Core signal connections:  Input-only pads
    output wire resetb_in,
    output wire clock_in,
    output wire option_in,

    // Core signal connections:  Bidirectional digital pads
    output wire flash_clk_in,
    output wire flash_clk_out,
    output wire flash_clk_ena,
    output wire flash_clk_one,
    output wire flash_clk_zero,
    output wire flash_csb_in,
    output wire flash_csb_out,
    output wire flash_csb_ena,
    output wire flash_csb_one,
    output wire flash_csb_zero,
    output wire flash_io0_in,
    output wire flash_io0_out,
    output wire flash_io0_ena,
    output wire flash_io0_one,
    output wire flash_io0_zero,
    output wire flash_io1_in,
    output wire flash_io1_out,
    output wire flash_io1_ena,
    output wire flash_io1_one,
    output wire flash_io1_zero,
    output wire flash_io2_in,
    output wire flash_io2_out,
    output wire flash_io2_ena,
    output wire flash_io2_one,
    output wire flash_io2_zero,
    output wire flash_io3_in,
    output wire flash_io3_out,
    output wire flash_io3_ena,
    output wire flash_io3_one,
    output wire flash_io3_zero,
    output wire gpio0_in,
    output wire gpio0_out,
    output wire gpio0_ena,
    output wire gpio0_one,
    output wire gpio0_zero,
    output wire gpio1_in,
    output wire gpio1_out,
    output wire gpio1_ena,
    output wire gpio1_one,
    output wire gpio1_zero,
    output wire spi_SDO_in,
    output wire spi_SDO_out,
    output wire spi_SDO_ena,
    output wire spi_SDO_one,
    output wire spi_SDO_zero,
    output wire spi_CSB_in,
    output wire spi_CSB_out,
    output wire spi_CSB_ena,
    output wire spi_CSB_one,
    output wire spi_CSB_zero,
    output wire spi_SDI_in,
    output wire spi_SDI_out,
    output wire spi_SDI_ena,
    output wire spi_SDI_one,
    output wire spi_SDI_zero,
    output wire spi_SCK_in,
    output wire spi_SCK_out,
    output wire spi_SCK_ena,
    output wire spi_SCK_one,
    output wire spi_SCK_zero,
    output wire UART_Rx_in,
    output wire UART_Rx_out,
    output wire UART_Rx_ena,
    output wire UART_Rx_one,
    output wire UART_Rx_zero,
    output wire UART_Tx_in,
    output wire UART_Tx_out,
    output wire UART_Tx_ena,
    output wire UART_Tx_one,
    output wire UART_Tx_zero,

    // Core signal connections:  User ID ROM
    output wire [31:0] mask_rev,

    // Core signal connections:  Analog
    inout wire [28:0] analog_io,
    inout wire [28:0] analog_io_esd
);

    // Instantiate the pads:

    // Corner pads

    sg13cmos5l_Corner corner_sw (
	`ifdef USE_POWER_PINS
	    .iovdd(vddio),
	    .iovss(vssio),
	    .vdd(vccd),
	    .vss(vssd)
	`endif	/* USE_POWER_PINS */
    );

    sg13cmos5l_Corner corner_se (
	`ifdef USE_POWER_PINS
	    .iovdd(vddio),
	    .iovss(vssio),
	    .vdd(vccd),
	    .vss(vssd)
	`endif	/* USE_POWER_PINS */
    );

    sg13cmos5l_Corner corner_nw (
	`ifdef USE_POWER_PINS
	    .iovdd(vddio),
	    .iovss(vssio),
	    .vdd(vccd),
	    .vss(vssd)
	`endif	/* USE_POWER_PINS */
    );

    sg13cmos5l_Corner corner_ne (
	`ifdef USE_POWER_PINS
	    .iovdd(vddio),
	    .iovss(vssio),
	    .vdd(vccd),
	    .vss(vssd)
	`endif	/* USE_POWER_PINS */
    );

    // Bottom side pads

    sg13cmos5l_IOPadVdd pad_vccd_0 (
	`ifdef USE_POWER_PINS
	    .iovdd(vddio),
	    .iovss(vssio),
	    .vdd(vccd),
	    .vss(vssd)
	`endif	/* USE_POWER_PINS */
    );

    sg13cmos5l_IOPadVss pad_vssio_0 (
	`ifdef USE_POWER_PINS
	    .iovdd(vddio),
	    .iovss(vssio),
	    .vdd(vccd),
	    .vss(vssd)
	`endif	/* USE_POWER_PINS */
    );

    sg13cmos5l_IOPadIn pad_resetb (
	`ifdef USE_POWER_PINS
	    .iovdd(vddio),
	    .iovss(vssio),
	    .vdd(vccd),
	    .vss(vssd),
	`endif	/* USE_POWER_PINS */
	.pad(resetb),
	.p2c(resetb_in)
    );

    sg13cmos5l_IOPadIn pad_gpio_38 (
	`ifdef USE_POWER_PINS
	    .iovdd(vddio),
	    .iovss(vssio),
	    .vdd(vccd),
	    .vss(vssd),
	`endif	/* USE_POWER_PINS */
	.pad(gpio[38]),
	.p2c(clock_in)
    );

    sg13cmos5l_IOPadVss pad_vssd_0 (
	`ifdef USE_POWER_PINS
	    .iovdd(vddio),
	    .iovss(vssio),
	    .vdd(vccd),
	    .vss(vssd)
	`endif	/* USE_POWER_PINS */
    );

    sg13cmos5l_IOPadInOut4mA pad_gpio_39 (
	`ifdef USE_POWER_PINS
	    .iovdd(vddio),
	    .iovss(vssio),
	    .vdd(vccd),
	    .vss(vssd),
	`endif	/* USE_POWER_PINS */
	.pad(gpio[39]),
	.c2p(flash_csb_out),
	.c2p_en(flash_csb_ena),
	.p2c(flash_csb_in)
    );

    sg13cmos5l_IOPadInOut4mA pad_gpio_40 (
	`ifdef USE_POWER_PINS
	    .iovdd(vddio),
	    .iovss(vssio),
	    .vdd(vccd),
	    .vss(vssd),
	`endif	/* USE_POWER_PINS */
	.pad(gpio[40]),
	.c2p(flash_clk_out),
	.c2p_en(flash_clk_ena),
	.p2c(flash_clk_in)
    );

    sg13cmos5l_IOPadInOut4mA pad_gpio_41 (
	`ifdef USE_POWER_PINS
	    .iovdd(vddio),
	    .iovss(vssio),
	    .vdd(vccd),
	    .vss(vssd),
	`endif	/* USE_POWER_PINS */
	.pad(gpio[41]),
	.c2p(flash_io0_out),
	.c2p_en(flash_io0_ena),
	.p2c(flash_io0_in)
    );

    sg13cmos5l_IOPadInOut4mA pad_gpio_42 (
	`ifdef USE_POWER_PINS
	    .iovdd(vddio),
	    .iovss(vssio),
	    .vdd(vccd),
	    .vss(vssd),
	`endif	/* USE_POWER_PINS */
	.pad(gpio[42]),
	.c2p(flash_io1_out),
	.c2p_en(flash_io1_ena),
	.p2c(flash_io1_in)
    );

    sg13cmos5l_IOPadInOut4mA pad_gpio_43 (
	`ifdef USE_POWER_PINS
	    .iovdd(vddio),
	    .iovss(vssio),
	    .vdd(vccd),
	    .vss(vssd),
	`endif	/* USE_POWER_PINS */
	.pad(gpio[43]),
	.c2p(gpio0_out),
	.c2p_en(gpio0_ena),
	.p2c(gpio0_in)
    );

    sg13cmos5l_IOPadIOVss pad_vssio_1 (
	`ifdef USE_POWER_PINS
	    .iovdd(vddio),
	    .iovss(vssio),
	    .vdd(vccd),
	    .vss(vssd)
	`endif	/* USE_POWER_PINS */
    );

    sg13cmos5l_IOPadIOVdd pad_vddio_0 (
	`ifdef USE_POWER_PINS
	    .iovdd(vddio),
	    .iovss(vssio),
	    .vdd(vccd),
	    .vss(vssd)
	`endif	/* USE_POWER_PINS */
    );

    // Right side pads

    sg13cmos5l_IOPadInOut4mA pad_gpio_0 (
	`ifdef USE_POWER_PINS
	    .iovdd(vddio),
	    .iovss(vssio),
	    .vdd(vccd),
	    .vss(vssd),
	`endif	/* USE_POWER_PINS */
	.pad(gpio[0]),
	.c2p(gpio1_out),
	.c2p_en(gpio1_ena),
	.p2c(gpio1_in)
    );

    sg13cmos5l_IOPadInOut4mA pad_gpio_1 (
	`ifdef USE_POWER_PINS
	    .iovdd(vddio),
	    .iovss(vssio),
	    .vdd(vccd),
	    .vss(vssd),
	`endif	/* USE_POWER_PINS */
	.pad(gpio[1]),
	.c2p(spi_SDO_out),
	.c2p_en(spi_SDO_ena),
	.p2c(spi_SDO_in)
    );

    sg13cmos5l_IOPadInOut4mA pad_gpio_2 (
	`ifdef USE_POWER_PINS
	    .iovdd(vddio),
	    .iovss(vssio),
	    .vdd(vccd),
	    .vss(vssd),
	`endif	/* USE_POWER_PINS */
	.pad(gpio[2]),
	.c2p(spi_SDI_out),
	.c2p_en(spi_SDI_ena),
	.p2c(spi_SDI_in)
    );

    sg13cmos5l_IOPadInOut4mA pad_gpio_3 (
	`ifdef USE_POWER_PINS
	    .iovdd(vddio),
	    .iovss(vssio),
	    .vdd(vccd),
	    .vss(vssd),
	`endif	/* USE_POWER_PINS */
	.pad(gpio[3]),
	.c2p(spi_CSB_out),
	.c2p_en(spi_CSB_ena),
	.p2c(spi_CSB_in)
    );

    sg13cmos5l_IOPadInOut4mA pad_gpio_4 (
	`ifdef USE_POWER_PINS
	    .iovdd(vddio),
	    .iovss(vssio),
	    .vdd(vccd),
	    .vss(vssd),
	`endif	/* USE_POWER_PINS */
	.pad(gpio[4]),
	.c2p(spi_SCK_out),
	.c2p_en(spi_SCK_ena),
	.p2c(spi_SCK_in)
    );

    sg13cmos5l_IOPadInOut4mA pad_gpio_5 (
	`ifdef USE_POWER_PINS
	    .iovdd(vddio),
	    .iovss(vssio),
	    .vdd(vccd),
	    .vss(vssd),
	`endif	/* USE_POWER_PINS */
	.pad(gpio[5]),
	.c2p(UART_Rx_out),
	.c2p_en(UART_Rx_ena),
	.p2c(UART_Rx_in)
    );

    sg13cmos5l_IOPadInOut4mA pad_gpio_6 (
	`ifdef USE_POWER_PINS
	    .iovdd(vddio),
	    .iovss(vssio),
	    .vdd(vccd),
	    .vss(vssd),
	`endif	/* USE_POWER_PINS */
	.pad(gpio[6]),
	.c2p(UART_Tx_out),
	.c2p_en(UART_Tx_ena),
	.p2c(UART_Tx_in)
    );

    sg13cmos5l_IOPadIOVss pad_vssio_2 (
	`ifdef USE_POWER_PINS
	    .iovdd(vddio),
	    .iovss(vssio),
	    .vdd(vccd),
	    .vss(vssd)
	`endif	/* USE_POWER_PINS */
    );

    sg13cmos5l_IOPadVss pad_vssd_1 (
	`ifdef USE_POWER_PINS
	    .iovdd(vddio),
	    .iovss(vssio),
	    .vdd(vccd),
	    .vss(vssd)
	`endif	/* USE_POWER_PINS */
    );

    sg13cmos5l_IOPadIOVdd pad_vddio_1 (
	`ifdef USE_POWER_PINS
	    .iovdd(vddio),
	    .iovss(vssio),
	    .vdd(vccd),
	    .vss(vssd)
	`endif	/* USE_POWER_PINS */
    );

    sg13cmos5l_IOPadAnalog pad_gpio_7 (
	`ifdef USE_POWER_PINS
	    .iovdd(vddio),
	    .iovss(vssio),
	    .vdd(vccd),
	    .vss(vssd),
	`endif	/* USE_POWER_PINS */
	.pad(gpio[7]),
	.padres(analog_io_esd[0])
    );

    sg13cmos5l_IOPadAnalog pad_gpio_8 (
	`ifdef USE_POWER_PINS
	    .iovdd(vddio),
	    .iovss(vssio),
	    .vdd(vccd),
	    .vss(vssd),
	`endif	/* USE_POWER_PINS */
	.pad(gpio[8]),
	.padres(analog_io_esd[1])
    );

    sg13cmos5l_IOPadAnalog pad_gpio_9 (
	`ifdef USE_POWER_PINS
	    .iovdd(vddio),
	    .iovss(vssio),
	    .vdd(vccd),
	    .vss(vssd),
	`endif	/* USE_POWER_PINS */
	.pad(gpio[9]),
	.padres(analog_io_esd[2])
    );

    sg13cmos5l_IOPadAnalog pad_gpio_10 (
	`ifdef USE_POWER_PINS
	    .iovdd(vddio),
	    .iovss(vssio),
	    .vdd(vccd),
	    .vss(vssd),
	`endif	/* USE_POWER_PINS */
	.pad(gpio[10]),
	.padres(analog_io_esd[3])
    );

    sg13cmos5l_IOPadAnalog pad_gpio_11 (
	`ifdef USE_POWER_PINS
	    .iovdd(vddio),
	    .iovss(vssio),
	    .vdd(vccd),
	    .vss(vssd),
	`endif	/* USE_POWER_PINS */
	.pad(gpio[11]),
	.padres(analog_io_esd[4])
    );

    sg13cmos5l_IOPadAnalog pad_gpio_12 (
	`ifdef USE_POWER_PINS
	    .iovdd(vddio),
	    .iovss(vssio),
	    .vdd(vccd),
	    .vss(vssd),
	`endif	/* USE_POWER_PINS */
	.pad(gpio[12]),
	.padres(analog_io_esd[5])
    );

    sg13cmos5l_IOPadIOVdd pad_vddio_2 (
	`ifdef USE_POWER_PINS
	    .iovdd(vddio),
	    .iovss(vssio),
	    .vdd(vccd),
	    .vss(vssd)
	`endif	/* USE_POWER_PINS */
    );

    sg13cmos5l_IOPadAnalog pad_gpio_13 (
	`ifdef USE_POWER_PINS
	    .iovdd(vddio),
	    .iovss(vssio),
	    .vdd(vccd),
	    .vss(vssd),
	`endif	/* USE_POWER_PINS */
	.pad(gpio[13]),
	.padres(analog_io_esd[6])
    );

    sg13cmos5l_IOPadVdd pad_vccd_1 (
	`ifdef USE_POWER_PINS
	    .iovdd(vddio),
	    .iovss(vssio),
	    .vdd(vccd),
	    .vss(vssd)
	`endif	/* USE_POWER_PINS */
    );

    sg13cmos5l_IOPadAnalog pad_gpio_14 (
	`ifdef USE_POWER_PINS
	    .iovdd(vddio),
	    .iovss(vssio),
	    .vdd(vccd),
	    .vss(vssd),
	`endif	/* USE_POWER_PINS */
	.pad(gpio[14]),
	.padres(analog_io_esd[7])
    );

    // Top side pads

    sg13cmos5l_IOPadAnalog pad_gpio_15 (
	`ifdef USE_POWER_PINS
	    .iovdd(vddio),
	    .iovss(vssio),
	    .vdd(vccd),
	    .vss(vssd),
	`endif	/* USE_POWER_PINS */
	.pad(gpio[15]),
	.padres(analog_io_esd[8])
    );

    sg13cmos5l_IOPadIOVss pad_vssio_3 (
	`ifdef USE_POWER_PINS
	    .iovdd(vddio),
	    .iovss(vssio),
	    .vdd(vccd),
	    .vss(vssd)
	`endif	/* USE_POWER_PINS */
    );

    sg13cmos5l_IOPadAnalog pad_gpio_16 (
	`ifdef USE_POWER_PINS
	    .iovdd(vddio),
	    .iovss(vssio),
	    .vdd(vccd),
	    .vss(vssd),
	`endif	/* USE_POWER_PINS */
	.pad(gpio[16]),
	.padres(analog_io_esd[9])
    );

    sg13cmos5l_IOPadAnalog pad_gpio_17 (
	`ifdef USE_POWER_PINS
	    .iovdd(vddio),
	    .iovss(vssio),
	    .vdd(vccd),
	    .vss(vssd),
	`endif	/* USE_POWER_PINS */
	.pad(gpio[17]),
	.padres(analog_io_esd[10])
    );

    sg13cmos5l_IOPadAnalog pad_gpio_18 (
	`ifdef USE_POWER_PINS
	    .iovdd(vddio),
	    .iovss(vssio),
	    .vdd(vccd),
	    .vss(vssd),
	`endif	/* USE_POWER_PINS */
	.pad(gpio[18]),
	.padres(analog_io_esd[11])
    );

    sg13cmos5l_IOPadIOVss pad_vssio_4 (
	`ifdef USE_POWER_PINS
	    .iovdd(vddio),
	    .iovss(vssio),
	    .vdd(vccd),
	    .vss(vssd)
	`endif	/* USE_POWER_PINS */
    );

    sg13cmos5l_IOPadAnalog pad_gpio_19 (
	`ifdef USE_POWER_PINS
	    .iovdd(vddio),
	    .iovss(vssio),
	    .vdd(vccd),
	    .vss(vssd),
	`endif	/* USE_POWER_PINS */
	.pad(gpio[19]),
