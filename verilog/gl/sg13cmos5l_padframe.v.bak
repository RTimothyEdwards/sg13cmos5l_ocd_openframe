    // Right side pads

    sg13cmos5l_IOPadAnalog pad_gpio_24 (
	`ifdef USE_POWER_PINS
	    .iovdd(vddio),
	    .iovss(vssio),
	    .vdd(vccd),
	    .vss(vssd),
	`endif	/* USE_POWER_PINS */
	.pad(gpio[24]),
