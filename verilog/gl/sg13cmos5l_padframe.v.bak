    sg13cmos5l_IOPadIn pad_option_0 (
	`ifdef USE_POWER_PINS
	    .iovdd(vddio),
	    .iovss(vssio),
	    .vdd(vccd),
	    .vss(vssd),
	`endif	/* USE_POWER_PINS */
	.pad(option),
	.p2c(option_in)
